# DATABASE
DATABASE_URL="mysql://root:@127.0.0.1:3306/sunspace"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY="7d"

# SERVER
PORT=3001
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000,http://192.168.x.x"

# FRONTEND URL (utilisé dans le lien de reset si l'origine HTTP n'est pas disponible)
FRONTEND_URL="http://localhost:65046"

# SMTP (obligatoire pour envoyer de vrais emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Sunspace <your-email@gmail.com>"
