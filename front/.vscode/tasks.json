{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Flutter Run (Auto Hot Reload)",
			"type": "shell",
			"command": "C:\\dev_mobile\\flutter\\bin\\flutter.bat",
			"args": [
				"run",
				"-d",
				"windows",
				"--verbose"
			],
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^Launching lib",
					"endsPattern": "^Application finished\\.|^Failed to build|^Build failed\\.|^Error:|^Exception:"
				}
			},
			"options": {
				"cwd": "${workspaceFolder}/front"
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared"
			}
		},
		{
			"label": "Run Flutter (Windows)",
			"type": "shell",
			"command": "C:\\dev_mobile\\flutter\\bin\\flutter.bat",
			"args": [
				"run",
				"-d",
				"windows"
			],
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe"
				}
			}
		},
		{
			"label": "Flutter Version Check",
			"type": "shell",
			"command": "C:\\dev_mobile\\flutter\\bin\\flutter.bat",
			"args": [
				"--version"
			],
			"isBackground": false,
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe"
				}
			}
		},
		{
			"label": "Flutter One Shot (Check + Run)",
			"type": "shell",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\.vscode\\flutter_run_check.ps1"
			],
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "Copilot Flutter Version Check",
			"type": "shell",
			"command": "C:\\dev_mobile\\flutter\\bin\\flutter.bat",
			"args": [
				"--version"
			],
			"isBackground": false
		},
		{
			"label": "Hot Reload (Appuyer R)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"Write-Host 'Pour hot reload, appuyez sur R dans le terminal Flutter. Ctrl+C pour arrêter.'"
			],
			"isBackground": false,
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}